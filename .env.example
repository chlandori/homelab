# Copy this file to .env on the host and fill in the values.
# The .env file must be located in the same directory as docker-compose.yml.

# Absolute Linux path where Jupyter notebook files will be stored persistently.
# Example: /mnt/storage/maxlab
NOTEBOOK_PATH=/mnt/storage/maxlab

# Secret token used to authenticate with the JupyterLab interface.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JUPYTER_TOKEN=changeme

